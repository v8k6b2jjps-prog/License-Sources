void SetHash(const UINT128u&amp; key3,UINT128u&amp; key2,UINT32u&amp; check=
)
{
  memcpy_s(&amp;key2,16,&amp;key3,16);

  check.u32=3DHash(key2);

  key2.u8[12]|=3Dcheck.u8[0] &lt;&lt; 7;
  key2.u8[13]=3D(check.u8[0] &gt;&gt; 1) | (check.u8[1] &lt;&lt; 7);
  key2.u8[14]|=3D(check.u8[1] &gt;&gt; 1) &amp; 0x1;
