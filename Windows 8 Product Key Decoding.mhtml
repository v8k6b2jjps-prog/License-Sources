void Encode(const UINT128u&amp; key2,UINT8 key1[25])
{
  UINT128u cur=3Dkey2;
  UINT64u res;
  UINT32u rem;

  UINT i=3D25;
  do
  {
    res.u64=3Dcur.u32[3];
    cur.u32[3]=3Dstatic_cast&lt;UINT32&gt;(res.u64/24);
    rem.u32=3Dres.u64 % 24;

    res.u32[0]=3Dcur.u32[2];
    res.u32[1]=3Drem.u32;
    cur.u32[2]=3Dstatic_cast&lt;UINT32&gt;(res.u64/24);
    rem.u32=3Dres.u64 % 24;

    res.u32[0]=3Dcur.u32[1];
    res.u32[1]=3Drem.u32;
    cur.u32[1]=3Dstatic_cast&lt;UINT32&gt;(res.u64/24);
