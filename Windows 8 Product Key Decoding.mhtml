bool CheckHash(const UINT128u&amp; key2,UINT128u&amp; key3,UINT32u&amp; che=
ck)
{
  check.u32=3D0;
  memcpy_s(&amp;key3,16,&amp;key2,16);

  key3.u8[12]&amp;=3D0x7f;
  key3.u8[13]=3D0;
  key3.u8[14]&amp;=3D0xfe;

  check.u8[0]=3D(key2.u8[13] &lt;&lt; 1) | (key2.u8[12] &gt;&gt; 7);
  check.u8[1]=3D((key2.u8[14] &lt;&lt; 1) | (key2.u8[13] &gt;&gt; 7)) &amp;=
 3;

  UINT32 hash=3DHash(key3);

  if(hash!=3Dcheck.u32)
  {
    std::wcout &lt;&lt; L"Invalid key. The hash is incorrect." &lt;&lt; std=
::endl;
    return false;
  }

  return true;
}

bool GetInfo(const UINT128u&amp; key3,UINT32u&amp; groupid,UINT32u&amp; key=
id,UINT64u&amp; secret)
{
