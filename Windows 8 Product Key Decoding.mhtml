  groupid.u8[0]=3Dkey3.u8[0];
  groupid.u8[1]=3Dkey3.u8[1];
  groupid.u8[2]=3Dkey3.u8[2] &amp; 0x0f;

  keyid.u8[0]=3D(key3.u8[2] &gt;&gt; 4) | (key3.u8[3] &lt;&lt; 4);
  keyid.u8[1]=3D(key3.u8[3] &gt;&gt; 4) | (key3.u8[4] &lt;&lt; 4);
  keyid.u8[2]=3D(key3.u8[4] &gt;&gt; 4) | (key3.u8[5] &lt;&lt; 4);
  keyid.u8[3]=3D((key3.u8[5] &gt;&gt; 4) | (key3.u8[6] &lt;&lt; 4)) &amp; 0=
x3f;

  secret.u8[0]=3D(key3.u8[6] &gt;&gt; 2) | (key3.u8[7] &lt;&lt; 6);
  secret.u8[1]=3D(key3.u8[7] &gt;&gt; 2) | (key3.u8[8] &lt;&lt; 6);
  secret.u8[2]=3D(key3.u8[8] &gt;&gt; 2) | (key3.u8[9] &lt;&lt; 6);
  secret.u8[3]=3D(key3.u8[9] &gt;&gt; 2) | (key3.u8[10] &lt;&lt; 6);
  secret.u8[4]=3D(key3.u8[10] &gt;&gt; 2) | (key3.u8[11] &lt;&lt; 6);
  secret.u8[5]=3D(key3.u8[11] &gt;&gt; 2) | (key3.u8[12] &lt;&lt; 6);
