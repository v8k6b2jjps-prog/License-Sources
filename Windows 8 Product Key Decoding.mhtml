  key3.u8[2]|=3Dkeyid.u8[0] &lt;&lt; 4;
  key3.u8[3]=3D(keyid.u8[1] &lt;&lt; 4) | (keyid.u8[0] &gt;&gt; 4);
  key3.u8[4]=3D(keyid.u8[2] &lt;&lt; 4) | (keyid.u8[1] &gt;&gt; 4);
  key3.u8[5]=3D(keyid.u8[3] &lt;&lt; 4) | (keyid.u8[2] &gt;&gt; 4);
  key3.u8[6]|=3D(keyid.u8[3] &gt;&gt; 4) &amp; 0x3;

  key3.u8[6]|=3Dsecret.u8[0] &lt;&lt; 2;
  key3.u8[7]=3D(secret.u8[1] &lt;&lt; 2) | (secret.u8[0] &gt;&gt; 6);
  key3.u8[8]=3D(secret.u8[2] &lt;&lt; 2) | (secret.u8[1] &gt;&gt; 6);
  key3.u8[9]=3D(secret.u8[3] &lt;&lt; 2) | (secret.u8[2] &gt;&gt; 6);
  key3.u8[10]=3D(secret.u8[4] &lt;&lt; 2) | (secret.u8[3] &gt;&gt; 6);
  key3.u8[11]=3D(secret.u8[5] &lt;&lt; 2) | (secret.u8[4] &gt;&gt; 6);
  key3.u8[12]|=3D((secret.u8[6] &lt;&lt; 2) | (secret.u8[5] &gt;&gt; 6)) &a=
mp; 0x7f;
